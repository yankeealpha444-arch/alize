# Vizard API key — server only (`npm run server:vizard`). Never put this in frontend code.
# Do NOT put your Vizard webhook URL here; configure the public webhook URL only in the Vizard dashboard.
VIZARDAI_API_KEY=

# Optional: port for the local Node server (default 8787)
VIZARD_SERVER_PORT=8787

# Frontend only: where the browser calls YOUR backend for POST /api/vizard (not a secret).
# This is not the webhook URL you give to Vizard.
VITE_VIZARD_BACKEND_URL=http://localhost:8787
